{
  "name": "cmux-mobile",
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile web app for accessing cmux workspaces from a smartphone browser",
  "bin": {
    "cmux-mobile": "./bin/cmux-mobile.js"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts start",
    "build": "tsup && rm -rf dist/client dist/shared && cp -r src/client dist/client && mkdir -p dist/shared && cp src/shared/types.ts dist/shared/types.ts && find dist -name .DS_Store -delete && find dist/client -name '*.test.*' -delete && node build-sw-cache.mjs",
    "start": "node dist/server/index.js start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.4.3",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.3.3",
    "json-rpc-2.0": "^1.7.1",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist/client",
    "dist/server/index.js",
    "dist/shared/types.ts",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  }
}
