{
  "name": "cmux-mobile",
  "version": "0.1.0",
  "description": "Mobile web app for accessing cmux workspaces from a smartphone browser",
  "bin": {
    "cmux-mobile": "./bin/cmux-mobile.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsup",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "chalk": "^5.4.1",
    "fastify": "^5.3.3",
    "json-rpc-2.0": "^1.7.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  }
}
