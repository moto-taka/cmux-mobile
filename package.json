{
  "name": "cmux-mobile",
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile web app for accessing cmux workspaces from a smartphone browser",
  "bin": {
    "cmux-mobile": "./bin/cmux-mobile.js"
  },
  "scripts": {
    "dev": "tsx src/server/index.ts start",
    "build": "tsup && rm -rf dist/client dist/shared && cp -r src/client dist/client && cp -r src/shared dist/shared",
    "start": "node dist/server/index.js start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.3.3",
    "json-rpc-2.0": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  }
}
